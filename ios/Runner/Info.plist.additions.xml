<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">

<!--
  ============================================================
  ios/Runner/Info.plist — EKLENMESİ GEREKEN SATIRLAR
  ============================================================
  Mevcut Info.plist dosyasının <dict> içine bunları ekle.
  Tüm dosyayı değiştirme, sadece bu key-value çiftlerini ekle!
  ============================================================
-->

<plist version="1.0">
<dict>

  <!-- ✅ Firebase Cloud Messaging — Push bildirimleri -->
  <key>FirebaseAppDelegateProxyEnabled</key>
  <false/>

  <!-- ✅ WorkManager — Arka plan görevleri (iOS 13+) -->
  <key>BGTaskSchedulerPermittedIdentifiers</key>
  <array>
    <string>be.tramckrijte.workmanager</string>
  </array>

  <!-- ✅ flutter_local_notifications — Bildirim izni -->
  <key>NSUserNotificationUsageDescription</key>
  <string>HataySepetim size sipariş güncellemeleri ve fırsatlar için bildirim gönderir.</string>

  <!-- ✅ image_picker — Fotoğraf kütüphanesi erişimi -->
  <key>NSPhotoLibraryUsageDescription</key>
  <string>Profil fotoğrafı veya ürün görseli seçmek için fotoğraf erişimi gereklidir.</string>

  <!-- ✅ image_picker — Kamera erişimi -->
  <key>NSCameraUsageDescription</key>
  <string>Fotoğraf çekmek için kamera erişimi gereklidir.</string>

  <!-- ✅ file_picker — Dosya erişimi -->
  <key>NSDocumentsFolderUsageDescription</key>
  <string>Dosya seçmek için erişim gereklidir.</string>

  <!-- ✅ url_launcher — Telefon açma (gerekirse) -->
  <key>LSApplicationQueriesSchemes</key>
  <array>
    <string>https</string>
    <string>http</string>
    <string>tel</string>
    <string>mailto</string>
  </array>

  <!-- ✅ App Store — Uygulama kısa açıklaması (opsiyonel ama önerilir) -->
  <key>CFBundleDisplayName</key>
  <string>HataySepetim</string>

</dict>
</plist>
